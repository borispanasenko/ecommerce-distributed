### WARNING

### This file changes local development data.

### Stock receipt requests are additive.

### Reservation commit requests decrease stock.

### Change runId before running the full flow again.

@InventoryApi_HostAddress = http://localhost:5245
@runId = 001

### Health check

GET {{InventoryApi_HostAddress}}/health

### List warehouses

GET {{InventoryApi_HostAddress}}/api/warehouses

### Create warehouse

# @name createWarehouse

POST {{InventoryApi_HostAddress}}/api/warehouses
Content-Type: application/json

{
"code": "MAIN-{{runId}}",
"name": "Main Warehouse {{runId}}"
}

### List warehouses after create

GET {{InventoryApi_HostAddress}}/api/warehouses

### Create location

@warehouseId = {{createWarehouse.response.body.$.id}}

# @name createLocation

POST {{InventoryApi_HostAddress}}/api/locations
Content-Type: application/json

{
"warehouseId": "{{warehouseId}}",
"code": "A-01-01"
}

### List locations

GET {{InventoryApi_HostAddress}}/api/locations

### List locations by warehouse

GET {{InventoryApi_HostAddress}}/api/locations?warehouseId={{warehouseId}}

### Receive stock

@locationId = {{createLocation.response.body.$.id}}
@sku = ARM-BLK-{{runId}}

POST {{InventoryApi_HostAddress}}/api/stock/receipts
Content-Type: application/json

{
"sku": "{{sku}}",
"warehouseId": "{{warehouseId}}",
"locationId": "{{locationId}}",
"quantity": 75,
"reason": "Initial stock"
}

### Get stock by SKU after receipt

GET {{InventoryApi_HostAddress}}/api/stock/{{sku}}

### Reserve stock

# @name reserveStock

POST {{InventoryApi_HostAddress}}/api/stock/reservations
Content-Type: application/json

{
"sku": "{{sku}}",
"warehouseId": "{{warehouseId}}",
"locationId": "{{locationId}}",
"quantity": 10,
"reference": "ORDER-{{runId}}-RELEASE"
}

### Get stock by SKU after reservation

GET {{InventoryApi_HostAddress}}/api/stock/{{sku}}

### Release reservation

@reservationId = {{reserveStock.response.body.$.id}}

POST {{InventoryApi_HostAddress}}/api/stock/reservations/{{reservationId}}/release

### Get stock by SKU after release

GET {{InventoryApi_HostAddress}}/api/stock/{{sku}}

### Reserve stock for commit

# @name reserveStockForCommit

POST {{InventoryApi_HostAddress}}/api/stock/reservations
Content-Type: application/json

{
"sku": "{{sku}}",
"warehouseId": "{{warehouseId}}",
"locationId": "{{locationId}}",
"quantity": 15,
"reference": "ORDER-{{runId}}-COMMIT"
}

### Commit reservation

@reservationToCommitId = {{reserveStockForCommit.response.body.$.id}}

POST {{InventoryApi_HostAddress}}/api/stock/reservations/{{reservationToCommitId}}/commit

### Get stock by SKU after commit

GET {{InventoryApi_HostAddress}}/api/stock/{{sku}}

### Get all stock movements

GET {{InventoryApi_HostAddress}}/api/stock/movements

### Get stock movements by SKU

GET {{InventoryApi_HostAddress}}/api/stock/movements?sku={{sku}}

### Missing SKU should return 404

GET {{InventoryApi_HostAddress}}/api/stock/MISSING-SKU

### Invalid receipt quantity should return 400

POST {{InventoryApi_HostAddress}}/api/stock/receipts
Content-Type: application/json

{
"sku": "{{sku}}",
"warehouseId": "{{warehouseId}}",
"locationId": "{{locationId}}",
"quantity": 0,
"reason": "Invalid receipt"
}

### Insufficient stock reservation should return 400

POST {{InventoryApi_HostAddress}}/api/stock/reservations
Content-Type: application/json

{
"sku": "{{sku}}",
"warehouseId": "{{warehouseId}}",
"locationId": "{{locationId}}",
"quantity": 999999,
"reference": "ORDER-{{runId}}-INSUFFICIENT"
}
